# Copy this file to ".env" and paste your real keys in.
# Do NOT commit the real .env to git.

# The brain — Gemma 4 on Cerebras (you already have this working)
CEREBRAS_API_KEY=csk-your-cerebras-key-here

# The ears — Deepgram streaming speech-to-text
DEEPGRAM_API_KEY=your-deepgram-key-here

# The voice — ElevenLabs text-to-speech
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# Optional: pick a specific ElevenLabs voice ID (defaults to a sensible one below).
# Browse voices at https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=
